# Discord webhook URL for the #claude-tokens channel
# Create one at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Your Claude Code weekly token budget.
# Leave empty to auto-detect from observed peaks and rate-limit errors.
# Max 5x plan  → ~225000000
# Max 20x plan → ~900000000
# Pro plan     → ~45000000
WEEKLY_TOKEN_BUDGET=

# Which day of the week does your Claude Code budget reset?
# 0=Monday (default), 6=Sunday
WEEK_START_DAY=0

# Hour (24h) to run the daily report when using launchd (default 9 = 09:00)
# Change this value BEFORE running install_schedule.sh
REPORT_HOUR=9
