# Discord webhook URL for the #claude-tokens channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Your Claude Code weekly token budget.
# Leave empty to auto-detect from observed peaks and rate-limit errors.
# Pro plan    → ~50000000  (50M, estimate)
# Max 5x plan → ~225000000
# Max 20x     → ~900000000
WEEKLY_TOKEN_BUDGET=

# Which day the week resets (0=Monday default)
WEEK_START_DAY=0

# Local hour when the week resets (24h). Claude Code Pro resets Monday 09:00.
WEEK_RESET_HOUR=9

# Hour for the launchd daily notification (19 = 19:00)
REPORT_HOUR=19
